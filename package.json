{
  "name": "n8n-nodes-incidentiq",
  "version": "0.1.0",
  "description": "n8n node for IncidentIQ API integration",
  "keywords": ["n8n-community-node-package", "n8n", "incidentiq", "itsm", "k12"],
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "tslint -p tsconfig.json -c tslint.json",
    "prepublishOnly": "npm run build"
  },
  "files": ["dist"],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": ["dist/credentials/IncidentIqApi.credentials.js"],
    "nodes": ["dist/nodes/IncidentIq/IncidentIq.node.js"]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
